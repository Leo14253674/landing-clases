<style>
  :root {
    --blue:        #1A5CFF;
    --blue-dark:   #0A3DCC;
    --blue-vivid:  #3B7BFF;
    --blue-pale:   #E8EFFE;
    --blue-light:  #D0DCFF;
    --sky:         #EEF3FF;
    --white:       #FFFFFF;
    --ink:         #0D1526;
    --ink-soft:    #2A3550;
    --text-muted:  #6B7A99;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--white);
    color: var(--ink);
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem 5rem;
    z-index: 100;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(26,92,255,0.1);
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.55rem;
    text-decoration: none;
  }
  .nav-logo-icon {
    width: 30px; height: 30px; border-radius: 50%;
    background: var(--blue);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .nav-logo-icon svg { display: block; }
  .nav-logo-text { display: flex; flex-direction: column; line-height: 1; }
  .nav-logo-name {
    font-family: 'Syne', sans-serif;
    font-weight: 800; font-size: 1.1rem;
    color: var(--ink); letter-spacing: -0.02em;
  }
  .nav-logo-name span { color: var(--blue); }
  .nav-logo-sub {
    font-size: 0.58rem; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-muted); margin-top: 1px;
  }
  .nav-links { display: flex; gap: 2rem; align-items: center; }
  .nav-link { font-size: 0.88rem; color: var(--text-muted); text-decoration: none; font-weight: 500; transition: color 0.2s; }
  .nav-link:hover { color: var(--blue); }
  .nav-cta {
    background: var(--blue); color: white;
    font-weight: 600; font-size: 0.88rem;
    padding: 0.6rem 1.6rem; border-radius: 2rem;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(26,92,255,0.3);
    transition: background 0.2s, transform 0.2s;
  }
  .nav-cta:hover { background: var(--blue-dark); transform: translateY(-1px); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    padding: 9rem 5rem 5rem;
    position: relative; overflow: hidden;
    background: linear-gradient(160deg, #fff 55%, var(--sky) 100%);
  }
  .blob { position: absolute; border-radius: 50%; filter: blur(70px); pointer-events: none; }
  .blob-1 { width:360px; height:360px; background:#C8D8FF; top:-80px; right:10%; opacity:0.6; }
  .blob-2 { width:220px; height:220px; background:#BFD4F7; bottom:8%; left:3%; opacity:0.5; }
  .hero-circle {
    position: absolute;
    width: 680px; height: 680px; border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, var(--blue-light), var(--blue-pale) 60%, transparent 80%);
    right: -160px; top: 50%; transform: translateY(-48%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: var(--blue-pale); border: 1px solid var(--blue-light);
    color: var(--blue); font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.4rem 1rem; border-radius: 2rem; width: fit-content;
    margin-bottom: 1.8rem;
    opacity: 0; animation: fadeUp 0.7s 0.1s forwards;
  }
  .badge-dot { width:6px; height:6px; border-radius:50%; background:var(--blue); animation: pulse 1.8s ease-in-out infinite; }

  h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3rem, 6.5vw, 6rem);
    font-weight: 800; letter-spacing: -0.03em; line-height: 1.0;
    max-width: 760px; margin-bottom: 1.5rem; color: var(--ink);
    opacity: 0; animation: fadeUp 0.8s 0.25s forwards;
  }
  h1 .hl { color: var(--blue); position: relative; display: inline-block; }
  h1 .hl::after {
    content: ''; position: absolute;
    bottom: 6px; left: 0; right: 0; height: 9px;
    background: var(--blue-light); border-radius: 4px; z-index: -1;
  }

  .hero-sub {
    font-size: 1.1rem; font-weight: 400; color: var(--text-muted);
    max-width: 500px; line-height: 1.75; margin-bottom: 2.5rem;
    opacity: 0; animation: fadeUp 0.8s 0.4s forwards;
  }
  .hero-actions {
    display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 4rem;
    opacity: 0; animation: fadeUp 0.8s 0.55s forwards;
  }
  .btn-primary {
    background: var(--blue); color: white; font-weight: 600; font-size: 0.95rem;
    padding: 0.85rem 2.2rem; border-radius: 2rem; text-decoration: none;
    box-shadow: 0 6px 28px rgba(26,92,255,0.35);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover { background: var(--blue-dark); transform: translateY(-2px); box-shadow: 0 10px 36px rgba(26,92,255,0.45); }
  .btn-ghost {
    border: 2px solid rgba(26,92,255,0.22); color: var(--blue); font-weight: 600; font-size: 0.95rem;
    padding: 0.85rem 2.2rem; border-radius: 2rem; text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-ghost:hover { border-color: var(--blue); background: var(--blue-pale); }

  .stat-row {
    display: flex; gap: 3rem; flex-wrap: wrap;
    opacity: 0; animation: fadeUp 0.8s 0.7s forwards;
  }
  .stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .stat-num { font-family:'Syne',sans-serif; font-size:2.4rem; font-weight:800; color:var(--blue); line-height:1; letter-spacing:-0.03em; }
  .stat-label { font-size:0.78rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--text-muted); font-weight:500; }
  .stat-div { width:1px; background:rgba(26,92,255,0.15); align-self:stretch; }

  /* MARQUEE */
  .marquee-section { background: var(--blue); padding: 1.1rem 0; overflow: hidden; }
  .marquee-track { display:flex; width:max-content; animation: marquee 24s linear infinite; }
  .marquee-item { display:flex; align-items:center; gap:1rem; padding:0 2rem; white-space:nowrap; font-size:0.82rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:rgba(255,255,255,0.85); }
  .m-dot { width:5px; height:5px; border-radius:50%; background:rgba(255,255,255,0.4); flex-shrink:0; }

  /* SECTIONS */
  .section { padding: 7rem 5rem; }
  .section-tag { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.72rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:var(--blue); margin-bottom:1rem; }
  .section-tag::before { content:''; width:1.5rem; height:2px; background:var(--blue); border-radius:2px; }
  .section-title { font-family:'Syne',sans-serif; font-size:clamp(1.9rem,3.5vw,3rem); font-weight:800; letter-spacing:-0.03em; line-height:1.1; max-width:580px; margin-bottom:0.8rem; color:var(--ink); }
  .section-title span { color: var(--blue); }
  .section-sub { font-size:1rem; color:var(--text-muted); line-height:1.7; max-width:500px; margin-bottom:3.5rem; }

  /* FEATURES */
  .features-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
  .feature-card {
    background: white; border: 1.5px solid rgba(26,92,255,0.1);
    border-radius: 1.2rem; padding: 2rem;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
    position: relative; overflow: hidden;
  }
  .feature-card::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,var(--blue-pale) 0%,transparent 60%); opacity:0; transition:opacity 0.3s; border-radius:inherit; }
  .feature-card:hover { transform:translateY(-4px); box-shadow:0 16px 48px rgba(26,92,255,0.12); border-color:rgba(26,92,255,0.3); }
  .feature-card:hover::before { opacity:1; }
  .feature-icon { width:3rem; height:3rem; border-radius:0.75rem; background:var(--blue-pale); border:1.5px solid var(--blue-light); display:flex; align-items:center; justify-content:center; font-size:1.4rem; margin-bottom:1.2rem; position:relative; z-index:1; }
  .feature-title { font-family:'Syne',sans-serif; font-size:1.1rem; font-weight:700; margin-bottom:0.6rem; color:var(--ink); position:relative; z-index:1; }
  .feature-desc { font-size:0.88rem; line-height:1.7; color:var(--text-muted); position:relative; z-index:1; }

  /* HOW */
  .how-section { padding:7rem 5rem; background:var(--sky); }
  .steps-layout { display:grid; grid-template-columns:1fr 1fr; gap:6rem; align-items:center; margin-top:3rem; }
  .steps-list { display:flex; flex-direction:column; gap:0; }
  .step { display:flex; gap:1.5rem; padding:1.8rem 0; border-bottom:1px solid rgba(26,92,255,0.1); transition:all 0.25s; }
  .step:last-child { border-bottom:none; }
  .step-num { font-family:'Syne',sans-serif; font-size:2.6rem; font-weight:800; color:var(--blue-light); line-height:1; flex-shrink:0; min-width:3.2rem; transition:color 0.3s; }
  .step:hover .step-num { color:var(--blue); }
  .step-content { padding-top:0.4rem; }
  .step-content h3 { font-family:'Syne',sans-serif; font-size:1.05rem; font-weight:700; margin-bottom:0.45rem; color:var(--ink); }
  .step-content p { font-size:0.88rem; line-height:1.7; color:var(--text-muted); }

  /* PHONE */
  .phone-wrap { display:flex; justify-content:center; align-items:center; position:relative; }
  .phone-glow { position:absolute; width:320px; height:320px; border-radius:50%; background:radial-gradient(circle,rgba(26,92,255,0.18) 0%,transparent 70%); filter:blur(40px); }
  .phone { width:270px; background:white; border-radius:2.8rem; border:2px solid rgba(26,92,255,0.15); box-shadow:0 40px 80px rgba(26,92,255,0.15),0 0 0 1px rgba(26,92,255,0.06); overflow:hidden; position:relative; animation:float 4s ease-in-out infinite; }
  .phone-bar { background:var(--blue); padding:1rem 1.2rem 0.8rem; display:flex; align-items:center; justify-content:space-between; }
  .p-avatar { width:34px; height:34px; border-radius:50%; background:rgba(255,255,255,0.25); display:flex; align-items:center; justify-content:center; font-size:0.8rem; font-weight:700; color:white; }
  .p-greeting { font-size:0.65rem; color:rgba(255,255,255,0.7); }
  .p-name { font-size:0.88rem; font-weight:700; color:white; }
  .phone-body { padding:1rem 1rem 1.5rem; display:flex; flex-direction:column; gap:0.8rem; }
  .p-xp-card { background:var(--sky); border-radius:0.8rem; padding:0.9rem; border:1px solid var(--blue-light); }
  .p-xp-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem; }
  .p-level { font-size:0.7rem; font-weight:600; color:var(--blue); }
  .p-pts { font-size:0.68rem; color:var(--text-muted); }
  .p-track { height:6px; background:var(--blue-light); border-radius:3px; overflow:hidden; }
  .p-fill { height:100%; width:68%; background:linear-gradient(90deg,var(--blue),var(--blue-vivid)); border-radius:3px; animation:xpPulse 2s ease-in-out infinite; }
  .p-reto { background:var(--blue); border-radius:0.8rem; padding:0.9rem 1rem; color:white; }
  .p-reto-badge { font-size:0.58rem; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.65); margin-bottom:0.35rem; }
  .p-reto-title { font-size:0.8rem; font-weight:700; line-height:1.3; margin-bottom:0.3rem; }
  .p-reto-desc { font-size:0.65rem; color:rgba(255,255,255,0.65); line-height:1.4; }
  .p-lb { background:white; border:1px solid rgba(26,92,255,0.12); border-radius:0.8rem; padding:0.8rem; }
  .p-lb-title { font-size:0.6rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:var(--text-muted); margin-bottom:0.5rem; }
  .p-lb-row { display:flex; align-items:center; gap:0.5rem; padding:0.28rem 0; font-size:0.68rem; }
  .p-lb-pos { color:var(--blue); font-weight:700; min-width:1.2rem; }
  .p-lb-name { flex:1; color:var(--ink-soft); }
  .p-lb-pts { color:var(--text-muted); }
  .p-lb-row.me { background:var(--blue-pale); border-radius:0.4rem; padding:0.28rem 0.4rem; }
  .p-lb-row.me .p-lb-name { color:var(--blue); font-weight:600; }
  .p-lb-row.me .p-lb-pts { color:var(--blue); font-weight:600; }

  /* BENEFITS */
  .benefits-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; margin-top:3.5rem; }
  .benefit-card { display:flex; align-items:flex-start; gap:1rem; padding:1.5rem; border-radius:1rem; border:1.5px solid rgba(26,92,255,0.1); background:white; transition:all 0.3s; }
  .benefit-card:hover { border-color:var(--blue); background:var(--blue-pale); transform:translateY(-2px); box-shadow:0 8px 24px rgba(26,92,255,0.1); }
  .benefit-icon { width:2.2rem; height:2.2rem; border-radius:0.5rem; background:var(--blue); color:white; display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
  .benefit-text strong { display:block; font-size:0.92rem; font-weight:600; color:var(--ink); margin-bottom:0.25rem; }
  .benefit-text p { font-size:0.84rem; line-height:1.6; color:var(--text-muted); }

  /* CTA */
  .cta-wrap { padding: 0 5rem 5rem; }
  .cta-section { background:var(--blue); border-radius:2rem; padding:6rem 4rem; text-align:center; position:relative; overflow:hidden; }
  .cta-section::before { content:''; position:absolute; width:500px; height:500px; border-radius:50%; background:rgba(255,255,255,0.07); top:-150px; right:-100px; pointer-events:none; }
  .cta-section::after { content:''; position:absolute; width:300px; height:300px; border-radius:50%; background:rgba(255,255,255,0.05); bottom:-100px; left:-60px; pointer-events:none; }
  .cta-tag { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.72rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:rgba(255,255,255,0.65); margin-bottom:1rem; justify-content:center; }
  .cta-tag::before { content:''; width:1.5rem; height:2px; background:rgba(255,255,255,0.35); border-radius:2px; }
  .cta-title { font-family:'Syne',sans-serif; font-size:clamp(2rem,4vw,3.2rem); font-weight:800; letter-spacing:-0.03em; color:white; line-height:1.1; margin-bottom:1rem; }
  .cta-sub { font-size:1rem; color:rgba(255,255,255,0.65); margin-bottom:2.5rem; }
  .btn-white { background:white; color:var(--blue); font-weight:700; font-size:0.95rem; padding:0.9rem 2.5rem; border-radius:2rem; text-decoration:none; display:inline-flex; align-items:center; gap:0.5rem; box-shadow:0 6px 24px rgba(0,0,0,0.15); transition:transform 0.2s, box-shadow 0.2s; }
  .btn-white:hover { transform:translateY(-2px); box-shadow:0 10px 32px rgba(0,0,0,0.2); }

  /* FOOTER */
  footer { padding:2rem 5rem; border-top:1px solid rgba(26,92,255,0.1); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; }
  /* footer logo variante 3 */
  .footer-logo { display:flex; align-items:center; gap:0.5rem; text-decoration:none; }
  .footer-logo-icon { width:26px; height:26px; border-radius:50%; background:var(--blue); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .footer-logo-text { display:flex; flex-direction:column; line-height:1; }
  .footer-logo-name { font-family:'Syne',sans-serif; font-weight:800; font-size:1rem; color:var(--ink); }
  .footer-logo-name span { color:var(--blue); }
  .footer-logo-sub { font-size:0.55rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-muted); margin-top:1px; }
  .footer-copy { font-size:0.8rem; color:var(--text-muted); }
  .footer-link { color:var(--blue); text-decoration:none; font-size:0.85rem; font-weight:500; transition:opacity 0.2s; }
  .footer-link:hover { opacity:0.7; }

  /* ANIMATIONS */
  @keyframes fadeUp { from { opacity:0; transform:translateY(22px); } to { opacity:1; transform:translateY(0); } }
  @keyframes marquee { from { transform:translateX(0); } to { transform:translateX(-50%); } }
  @keyframes float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-12px); } }
  @keyframes pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.5; transform:scale(0.8); } }
  @keyframes xpPulse { 0%,100% { box-shadow:0 0 0 0 rgba(26,92,255,0); } 50% { box-shadow:0 0 10px 2px rgba(26,92,255,0.3); } }

  .reveal { opacity:0; transform:translateY(28px); transition:opacity 0.75s ease, transform 0.75s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }

  @media (max-width:960px) {
    nav { padding:1rem 2rem; }
    .nav-links { display:none; }
    .hero, .section, .how-section { padding:5rem 2rem 4rem; }
    .features-grid { grid-template-columns:1fr; }
    .steps-layout { grid-template-columns:1fr; gap:2.5rem; }
    .phone-wrap { display:none; }
    .benefits-grid { grid-template-columns:1fr; }
    .cta-wrap { padding:0 1.5rem 3rem; }
    footer { padding:2rem; flex-direction:column; text-align:center; }
  }
</style>
</head>
